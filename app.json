{
  "expo": {
    "name": "Memo",
    "slug": "memo-frontend",
    "scheme": "memo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0A2E"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yourusername.memo",
      "infoPlist": {
        "NSCameraUsageDescription": "Memo uses your camera to capture moments",
        "NSMicrophoneUsageDescription": "Memo uses your microphone for voice notes",
        "NSPhotoLibraryUsageDescription": "Memo accesses your photos so you can post them"
      }
    },
    "android": {
      "package": "com.yourusername.memo",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": ["CAMERA", "RECORD_AUDIO", "READ_EXTERNAL_STORAGE", "WRITE_EXTERNAL_STORAGE"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      ["expo-camera", { "cameraPermission": "Allow Memo to access your camera" }],
      ["expo-av", { "microphonePermission": "Allow Memo to access your microphone" }],
      "expo-local-authentication"
    ]
  }
}
